{
  "url": "https://member.myfreescorenow.com/login/",
  "puppeteerConfig": {
    "headless": "new",
    "ignoreHTTPSErrors": false,
    "userDataDir": "./userData",
    "devtools": false,
    "args": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-gpu",
      "--disable-web-security",
      "--disable-features=VizDisplayCompositor"
    ],
    "ignoreDefaultArgs": [
      "--disable-extensions"
    ]
  },
  "puppeteerResolution": {
    "width": 1024,
    "height": 720
  },
  "puppeteerPreloadJs": [
    "./preload.js"
  ],
  "puppeteerHttpHeaders": {
    "Accept-Language": "en"
  },
  "evaluations": {
    "get_ceo_info": "__NEXT_DATA__.props.pageProps.initialState.ceoDetail",
    "get_state_data": "__NEXT_DATA__.props.pageProps.initialState"
  },
  "selectors": {
    "captcha_app": "#captcha-app",
    "login_page": ".content-wrapper.flex.owler-mod.css-33yiqnal.sign-in",
    "click_to_username_field": "#email",
    "click_to_password_field": "#password",
    "click_to_signin": "#nav-search-submit-button",
    "search_field": "#twotabsearchtextbox",
    "search_button": "button.swSearch-submit[type='submit']",
    "get_search_list": "ul.list-group.search-list > div.list-group-item"
  }
}