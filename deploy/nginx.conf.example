## Final HTTPS config.
## Do not enable this file until the certificate paths below exist.
## For first-time setup, start from deploy/nginx.http-bootstrap.conf.example, obtain the cert with certbot, then switch to this file.

server {
    listen 80;
    listen [::]:80;
    server_name thescoremachine.com www.thescoremachine.com admin.thescoremachine.com super-admin.thescoremachine.com affiliate.thescoremachine.com support.thescoremachine.com funding-manager.thescoremachine.com member.thescoremachine.com ref.thescoremachine.com api.thescoremachine.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name thescoremachine.com www.thescoremachine.com admin.thescoremachine.com super-admin.thescoremachine.com affiliate.thescoremachine.com support.thescoremachine.com funding-manager.thescoremachine.com member.thescoremachine.com ref.thescoremachine.com api.thescoremachine.com;

    # Managed by Certbot. If you use a wildcard certificate, update these paths.
    ssl_certificate /etc/letsencrypt/live/thescoremachine.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/thescoremachine.com/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/thescoremachine.com/chain.pem;

    # Optional hardening. Only keep includeSubDomains once every listed subdomain serves HTTPS.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # WebSocket endpoint
    location /socket.io/ {
        proxy_pass http://127.0.0.1:3001/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # All app routes (SPA + API)
    location / {
        proxy_pass http://127.0.0.1:3001/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "keep-alive";
    }
}